# Wallet Private Keys (REQUIRED for on-chain actions)
# Use ONE of these depending on code path (some older code expects PRIVATE_KEY)
DEPLOYER_PRIVATE_KEY=
PRIVATE_KEY=

# Optional (only if you use these flows)
BUYER_PRIVATE_KEY=
VENDOR_PRIVATE_KEY=
ARBITER_PRIVATE_KEY=

# Default Configuration / role addresses
ARBITER_ADDRESS=
FEE_RECIPIENT_ADDRESS=

# Fees / rates
DEFAULT_FEE_BPS=100
DEFAULT_BUYER_FEE_BPS=50
DEFAULT_VENDOR_FEE_BPS=50
DEFAULT_DISPUTE_FEE_BPS=50
DEFAULT_REWARD_RATE_BPS=25

# Security
PASSWORD_SALT_ROUNDS=10
JWT_SECRET=change-me-local-dev
JWT_EXPIRES_IN=7d

# Uploads
IMAGE_UPLOAD_MAX_SIZE_BYTES=5242880

# Logging
LOG_LEVEL=debug

# Rate Limiting
