BSC_TESTNET_RPC_URL=https://bsc-testnet-rpc.publicnode.com/
BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org
# Optional override used by backend if set:
BSC_RPC_URL=https://bsc-rpc.publicnode.com/

# Explorer base URL used for notification links
# (Change to https://bscscan.com on mainnet)
BSC_SCAN_URL=https://bscscan.com

# Stablecoin Addresses
