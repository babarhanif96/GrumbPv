# Testnet reference:
# NEXT_PUBLIC_CHAIN_ID=0x61
# NEXT_PUBLIC_CHAIN_NAME=BNB Smart Chain Testnet
# NEXT_PUBLIC_NATIVE_CURRENCY_NAME=Binance Coin
# NEXT_PUBLIC_NATIVE_CURRENCY_SYMBOL=tBNB
