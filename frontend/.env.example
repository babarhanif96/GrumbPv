NEXT_PUBLIC_ESCROW_BACKEND_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_ESCROW_BACKEND_UPLOADS_URL=http://localhost:5000/uploads

# --- VPS dev (e.g. dev.grumbuild.com; nginx → Next :3001, API :5001) ---
# Use HTTPS + paths your nginx exposes to the browser (NOT 127.0.0.1 — users cannot reach the VPS loopback).
# Example if nginx proxies https://dev.grumbuild.com/backend/ → backend:
# NEXT_PUBLIC_ESCROW_BACKEND_URL=https://dev.grumbuild.com/backend/api/v1
# NEXT_PUBLIC_ESCROW_BACKEND_UPLOADS_URL=https://dev.grumbuild.com/backend/uploads
# WebSocket must match how nginx proxies Socket.IO (often wss + same host):
# NEXT_PUBLIC_ESCROW_WEBSOCKET_URL=wss://dev.grumbuild.com

NEXT_PUBLIC_ESCROW_WEBSOCKET_URL=
NEXT_PUBLIC_IPFS_GATEWATY_URL=
NEXT_IMAGE_UNOPTIMIZED=